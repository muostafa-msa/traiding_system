MARKET_DATA_PROVIDER=twelvedata
MARKET_DATA_API_KEY=your_key_here
INITIAL_CAPITAL=10000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SIGNAL_THRESHOLD=0.68
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_RISK=0.03
MAX_OPEN_POSITIONS=2
KILL_SWITCH_THRESHOLD=0.05
SL_ATR_MULTIPLIER=1.5
TP_ATR_MULTIPLIER=3.0
LOG_LEVEL=INFO
DB_PATH=storage/trading.db

# RSS News Feeds (comma-separated URLs)
RSS_FEED_URLS=
RSS_KEYWORDS=gold,inflation,fed,interest rate,usd,war,oil,cpi,nfp
BLACKOUT_KEYWORDS=fed,fomc,nfp,non-farm,cpi,consumer price,interest rate decision
BLACKOUT_DURATION_HOURS=4.0
SENTIMENT_WINDOW_HOURS=4.0

# Model settings
FINBERT_MODEL_PATH=models/finbert
MODEL_DEVICE=auto

# LSTM model
LSTM_MODEL_PATH=models/lstm
LSTM_SEQUENCE_LENGTH=60
LSTM_DIRECTION_THRESHOLD=0.15

# XGBoost model
XGBOOST_MODEL_PATH=models/xgboost

# Ollama (GPT-OSS-20B explanation generation)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_ENABLED=false
EXPLANATION_MAX_TOKENS=150
EXPLANATION_TEMPERATURE=0.7

# Fallback weights for probability scoring (must sum to 1.0)
FALLBACK_WEIGHT_INDICATORS=0.30
FALLBACK_WEIGHT_PATTERNS=0.20
FALLBACK_WEIGHT_SENTIMENT=0.25
FALLBACK_WEIGHT_PREDICTION=0.25

# Decision window for best-signal-wins deduplication (minutes)
DECISION_WINDOW_MINUTES=15

# Signal quality gates (006-signal-quality-filters)
PREDICTION_AGREEMENT_ENABLED=true
MTF_CONFIRMATION_ENABLED=true
MTF_MIN_AGREEING_TIMEFRAMES=2
OPPORTUNITY_SCORE_ENABLED=true
OPPORTUNITY_SCORE_THRESHOLD=0.55
